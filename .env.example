# Identity Prism — Environment Variables

# ─── Frontend (Vite) ───
VITE_HELIUS_API_KEY=
VITE_HELIUS_API_KEYS=key1,key2
VITE_HELIUS_PROXY_URL=https://your-domain.com
VITE_APP_BASE_URL=https://identityprism.xyz
VITE_METADATA_BASE_URL=https://your-domain.com
VITE_METADATA_IMAGE_URL=https://your-domain.com/assets/identity-prism.png
VITE_COLLECTION_MINT=
VITE_UPDATE_AUTHORITY=
VITE_COLLECTION_VERIFY_URL=https://your-domain.com
VITE_CNFT_MINT_URL=https://your-domain.com
VITE_TAPESTRY_API_KEY=

# Firebase Analytics (optional — analytics disabled if not set)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Server ───
PORT=3000
HOST=0.0.0.0
HELIUS_API_KEYS=key1,key2
HELIUS_RPC_BASE=https://mainnet.helius-rpc.com/
ALCHEMY_RPC_URL=
FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com
JWT_SECRET=
ADMIN_KEY=your-secret-admin-key
CORS_ORIGIN=https://identityprism.xyz
REPUTATION_API_KEYS=key1,key2
COLLECTION_AUTHORITY_SECRET=
PUBLIC_BASE_URL=https://identityprism.xyz
TAPESTRY_API_KEY=

# Firebase Admin (server-side) — path to service account JSON
FIREBASE_SERVICE_ACCOUNT=./server/firebase-service-account.json
